{
  "name": "node-orm-migration-guard",
  "version": "0.2.0",
  "description": "Unified migration safety guard for popular Node.js ORMs and migration tools.",
  "type": "module",
  "main": "./src/index.cjs",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "require": "./src/index.cjs",
      "default": "./src/index.js"
    },
    "./core": {
      "types": "./src/core.d.ts",
      "import": "./src/core.js",
      "require": "./src/core.cjs",
      "default": "./src/core.js"
    },
    "./drizzle": {
      "types": "./src/drizzle.d.ts",
      "import": "./src/drizzle.js",
      "require": "./src/drizzle.cjs",
      "default": "./src/drizzle.js"
    },
    "./knex": {
      "types": "./src/knex.d.ts",
      "import": "./src/knex.js",
      "require": "./src/knex.cjs",
      "default": "./src/knex.js"
    },
    "./objection": {
      "types": "./src/knex.d.ts",
      "import": "./src/knex.js",
      "require": "./src/knex.cjs",
      "default": "./src/knex.js"
    },
    "./mikro": {
      "types": "./src/mikro-orm.d.ts",
      "import": "./src/mikro-orm.js",
      "require": "./src/mikro-orm.cjs",
      "default": "./src/mikro-orm.js"
    },
    "./mikro-orm": {
      "types": "./src/mikro-orm.d.ts",
      "import": "./src/mikro-orm.js",
      "require": "./src/mikro-orm.cjs",
      "default": "./src/mikro-orm.js"
    },
    "./mikroorm": {
      "types": "./src/mikro-orm.d.ts",
      "import": "./src/mikro-orm.js",
      "require": "./src/mikro-orm.cjs",
      "default": "./src/mikro-orm.js"
    },
    "./prisma": {
      "types": "./src/prisma.d.ts",
      "import": "./src/prisma.js",
      "require": "./src/prisma.cjs",
      "default": "./src/prisma.js"
    },
    "./sequelize": {
      "types": "./src/sequelize.d.ts",
      "import": "./src/sequelize.js",
      "require": "./src/sequelize.cjs",
      "default": "./src/sequelize.js"
    },
    "./typeorm": {
      "types": "./src/typeorm.d.ts",
      "import": "./src/typeorm.js",
      "require": "./src/typeorm.cjs",
      "default": "./src/typeorm.js"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "node --test ../../test/adapters.test.js",
    "prepublishOnly": "npm test"
  },
  "dependencies": {
    "drizzle-migration-guard": "0.2.0",
    "knex-migration-guard": "0.2.0",
    "migration-guard-core": "0.2.0",
    "mikro-orm-migration-guard": "0.2.0",
    "prisma-migration-guard": "0.2.0",
    "sequelize-migration-guard": "0.2.0",
    "typeorm-migration-guard": "0.2.0"
  },
  "keywords": [
    "migration",
    "database",
    "orm",
    "typeorm",
    "prisma",
    "sequelize",
    "knex",
    "drizzle",
    "mikro-orm",
    "guard"
  ],
  "author": {
    "name": "Luis Aneuris Tavarez De Jesus",
    "url": "https://www.ltavarez.me/"
  },
  "homepage": "https://www.ltavarez.me/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uppy19d0/node-orm-migration-guards.git",
    "directory": "packages/node-orm-migration-guard"
  },
  "bugs": {
    "url": "https://github.com/uppy19d0/node-orm-migration-guards/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
